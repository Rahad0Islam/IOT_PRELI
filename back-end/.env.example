# Copy this file to `.env` and fill in any values you want to override.
# All variables below have working defaults — the server starts with an empty .env.

# ─── HTTP server ────────────────────────────────────────────────
PORT=4000
CORS_ORIGINS=*
LOG_LEVEL=info

# ─── Office hours (integer hours, 0-23) ─────────────────────────
OFFICE_START_HOUR=9
OFFICE_END_HOUR=17

# ─── Alert engine ───────────────────────────────────────────────
DEVICE_RUNTIME_ALERT_MINUTES=120
ALERT_SCAN_INTERVAL_MS=60000

# ─── Built-in device simulator ──────────────────────────────────
SIMULATOR_ENABLED=true
SIMULATOR_INTERVAL_MS=12000

# ─── Runtime service ────────────────────────────────────────────
RUNTIME_PERSIST_INTERVAL_MS=30000
RUNTIME_TICK_INTERVAL_MS=30000

# ─── Discord bot (leave DISCORD_TOKEN empty to disable the bot) ─
DISCORD_TOKEN=
DISCORD_ALERT_CHANNEL_ID=
DISCORD_GUILD_IDS=

# ─── Google Gemini (leave GEMINI_API_KEY empty for rule-based fallback) ─
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash