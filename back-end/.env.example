# --- Server ---
PORT=4000
NODE_ENV=development

# --- Office hours ---
# Integer hours 0..23 (NOT HH:MM strings).
# Office is "in hours" when start <= now_hour < end.
OFFICE_START_HOUR=9
OFFICE_END_HOUR=17

# Continuous-runtime alert fires when a device has been ON for longer
# than this many minutes. Default 120 (2 hours).
DEVICE_RUNTIME_ALERT_MINUTES=120

# --- Discord Bot ---
# Token of your Discord bot (https://discord.com/developers/applications)
DISCORD_TOKEN=
# Channel ID where the bot will proactively post alerts
DISCORD_ALERT_CHANNEL_ID=
# Comma-separated guild IDs (servers) the bot should listen to. Leave empty to listen globally.
DISCORD_GUILD_IDS=

# --- Google Gemini (used to humanize bot responses) ---
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional model override; defaults to "gemini-1.5-flash"
GEMINI_MODEL=

