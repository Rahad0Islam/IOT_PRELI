{
  "name": "office-iot-backend",
  "version": "1.0.0",
  "description": "Real-time office IoT monitoring backend (REST + Socket.IO + Discord bot + simulator + alert engine)",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "iot",
    "express",
    "socket.io",
    "lowdb",
    "discord-bot",
    "typescript"
  ],
  "author": "Rahad",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "axios": "^1.7.7",
    "cors": "^2.8.5",
    "discord.js": "^14.16.3",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-validator": "^7.2.0",
    "lowdb": "^7.0.1",
    "socket.io": "^4.8.1",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.1",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3"
  }
}
